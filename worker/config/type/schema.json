{
  "$id": "https://github.com/data-fair/catalogs/worker/config",
  "x-exports": [
    "types",
    "validate"
  ],
  "x-ajv": {
    "coerceTypes": "array"
  },
  "type": "object",
  "title": "Worker config",
  "additionalProperties": false,
  "required": [
    "cipherPassword",
    "dataFairAPIKey",
    "host",
    "mongoUrl",
    "observer",
    "privateDataFairUrl",
    "privateRegistryUrl",
    "secretKeys",
    "upgradeRoot",
    "worker"
  ],
  "properties": {
    "cipherPassword": {
      "type": "string"
    },
    "dataDir": {
      "type": ["string", "null"],
      "description": "Optional. When set, the legacy plugins volume at <dataDir>/plugins is read by the v1.0.0 boot migration. Removed in v2.0.0."
    },
    "dataFairAPIKey": {
      "type": "string"
    },
    "host": {
      "type": "string",
      "description": "This is used to define the 'host' header in the requests to the DataFair API."
    },
    "mongoUrl": {
      "type": "string"
    },
    "observer": {
      "type": "object",
      "properties": {
        "active": {
          "type": "boolean"
        },
        "port": {
          "type": "number"
        }
      }
    },
    "privateDataFairUrl": {
      "type": "string",
      "pattern": "^https?://"
    },
    "privateEventsUrl": {
      "type": "string"
    },
    "privateRegistryUrl": {
      "type": "string",
      "pattern": "^https?://",
      "description": "Internal URL used by the worker to call the registry server-to-server."
    },
    "secretKeys": {
      "type": "object",
      "required": [
        "registry"
      ],
      "properties": {
        "events": {
          "type": "string"
        },
        "registry": {
          "type": "string",
          "description": "x-secret-key shared with the registry."
        }
      }
    },
    "tmpDir": {
      "type": "string"
    },
    "upgradeRoot": {
      "type": "string"
    },
    "worker": {
      "type": "object",
      "required": [
        "interval",
        "inactiveInterval",
        "inactivityDelay",
        "concurrency"
      ],
      "properties": {
        "interval": {
          "description": "Base interval for polling the database for new resources to work on",
          "type": "number"
        },
        "inactiveInterval": {
          "description": "Interval for polling the database when the worker is inactive (no resource found recently)",
          "type": "number"
        },
        "inactivityDelay": {
          "description": "Delay before the worker goes inactive",
          "type": "number"
        },
        "concurrency": {
          "description": "Number of concurrent processes the worker can run",
          "type": "number"
        }
      }
    },
    "util": {},
    "get": {},
    "has": {}
  }
}