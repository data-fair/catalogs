# nginx configuration file for the catalogs development and test environment
# Processed by the stock nginx image entrypoint (envsubst on ${VAR} tokens),
# the result overwrites /etc/nginx/conf.d/default.conf.

server {
  listen ${NGINX_PORT};
  server_name ${DEV_HOST};

  # Transmit host, protocol and user ip, we use it for routing, rate limiting, etc.
  proxy_set_header Host $http_host;
  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Proto $scheme;
  proxy_set_header X-Forwarded-Host $http_host;
  proxy_set_header X-Real-IP $remote_addr;
  proxy_set_header X-Client-IP $remote_addr;

  # web socket support
  proxy_set_header Upgrade $http_upgrade;
  proxy_set_header Connection "Upgrade";

  # accept some occasional long queries + HMR long poll from the Vite dev server
  proxy_read_timeout 86400;
  # set client body size to 1 GB
  client_max_body_size 1G;

  location = / {
    return 302 /catalogs/;
  }

  location = /catalogs/ {
    return 302 /catalogs/dev;
  }

  # API routes served by the API server
  location /catalogs/api/ {
    proxy_pass http://localhost:${DEV_API_PORT};
  }

  # ui-config served by the API server
  location ~ /catalogs/(.*)-ui-config.js {
    proxy_pass http://localhost:${DEV_API_PORT};
  }

  # UI served by the Vite dev server
  location /catalogs/ {
    proxy_pass http://localhost:${DEV_UI_PORT};
  }

  location /simple-directory/ {
    proxy_pass http://localhost:${SD_PORT};
  }

  location /data-fair {
    rewrite ^/data-fair/(.*) /$1 break;
    proxy_pass http://localhost:${DF_PORT}/;
  }

  location /events/ {
    proxy_pass http://localhost:${EVENTS_PORT};
  }

  # registry — same domain so the catalogs UI lists artefacts directly with
  # the SimpleDirectory session cookie. The registry expects the /registry
  # prefix in the URL (PUBLIC_URL=...registry).
  location /registry/ {
    proxy_pass http://localhost:${REGISTRY_PORT};
  }
}
