{
  "$id": "https://github.com/data-fair/catalogs/api/config",
  "x-exports": [
    "types",
    "validate"
  ],
  "x-ajv": {
    "coerceTypes": "array"
  },
  "type": "object",
  "title": "Api config",
  "additionalProperties": false,
  "required": [
    "cipherPassword",
    "mongoUrl",
    "observer",
    "port",
    "privateDirectoryUrl",
    "privateRegistryUrl",
    "secretKeys"
  ],
  "properties": {
    "cipherPassword": {
      "type": "string"
    },
    "dataDir": {
      "type": ["string", "null"],
      "description": "Optional. When set, the legacy plugins volume at <dataDir>/plugins is read by the v1.0.0 boot migration. Removed in v2.0.0."
    },
    "mongoUrl": {
      "type": "string"
    },
    "observer": {
      "type": "object",
      "properties": {
        "active": {
          "type": "boolean"
        },
        "port": {
          "type": "number"
        }
      }
    },
    "port": {
      "type": "number"
    },
    "privateDirectoryUrl": {
      "type": "string",
      "pattern": "^https?://"
    },
    "privateEventsUrl": {
      "type": "string"
    },
    "privateRegistryUrl": {
      "type": "string",
      "pattern": "^https?://",
      "description": "Internal URL used by the API to call the registry server-to-server. The UI hits /registry on the same domain."
    },
    "secretKeys": {
      "type": "object",
      "required": [
        "catalogs",
        "identities",
        "registry"
      ],
      "properties": {
        "catalogs": {
          "type": "string"
        },
        "events": {
          "type": "string"
        },
        "identities": {
          "type": "string"
        },
        "registry": {
          "type": "string",
          "description": "x-secret-key shared with the registry (matches the registry's secretKeys.internalServices)."
        }
      }
    },
    "tmpDir": {
      "type": "string",
      "description": "dataDir + '/tmp' if undefined"
    },
    "util": {},
    "get": {},
    "has": {}
  }
}